# ==================================
# AI Compliance System Configuration
# ==================================

# MongoDB Configuration
MONGO_USER=compliance_admin
MONGO_PASSWORD=compliance_secret_change_me
MONGODB_URI=mongodb://compliance_admin:compliance_secret_change_me@localhost:27017/compliance_db?authSource=admin

# Redis Configuration
REDIS_URI=redis://localhost:6379

# Service URLs (for local development)
CRAWLER_SERVICE_URL=http://localhost:8001
OCR_SERVICE_URL=http://localhost:8002
NLP_SERVICE_URL=http://localhost:8003
COMPLIANCE_ENGINE_URL=http://localhost:8004
RULE_ENGINE_URL=http://localhost:8005
REPORTING_SERVICE_URL=http://localhost:8006

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Security (generate your own secrets)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
API_KEY_SALT=your-api-key-salt-change-this

# External APIs (optional)
OPENAI_API_KEY=your-openai-api-key
GOOGLE_CLOUD_VISION_KEY=your-google-cloud-key

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
CRAWL_DELAY_SECONDS=2

# OCR Configuration
TESSERACT_LANGUAGES=eng,hin,tam,tel,kan,mar,ben,guj

# Monitoring (optional)
PROMETHEUS_ENABLED=false
GRAFANA_ADMIN_PASSWORD=admin

# Environment
ENVIRONMENT=development
DEBUG=true
