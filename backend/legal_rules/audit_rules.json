{
  "metadata": {
    "act": "Legal Metrology Act, 2009",
    "rules": "Legal Metrology (Packaged Commodities) Rules, 2011",
    "version": "2.0",
    "applicability": "Retail packages sold in India including e-commerce listings"
  },
  "rules": [
    {
      "code": "LM-AUD-001",
      "field": "mrp_inclusive_of_taxes",
      "mandatory": true,
      "penalty": 20,
      "message": "Missing MRP declaration (inclusive of all taxes).",
      "legal_reference": "Rule 6(1)(e) - Retail sale price mandatory"
    },
    {
      "code": "LM-AUD-002",
      "field": "net_quantity",
      "mandatory": true,
      "penalty": 20,
      "message": "Missing net quantity declaration.",
      "legal_reference": "Rule 6(1)(c) - Net quantity mandatory"
    },
    {
      "code": "LM-AUD-003",
      "field": "manufacturer_or_importer",
      "mandatory": true,
      "penalty": 20,
      "message": "Missing manufacturer/importer details.",
      "legal_reference": "Rule 6(1)(a) - Manufacturer name and address mandatory"
    },
    {
      "code": "LM-AUD-004",
      "field": "consumer_care_information",
      "mandatory": true,
      "penalty": 15,
      "message": "Missing consumer care information.",
      "legal_reference": "Rule 6(1)(f) - Customer care details mandatory"
    },
    {
      "code": "LM-AUD-005",
      "field": "date_of_manufacture_or_import",
      "mandatory": true,
      "penalty": 15,
      "message": "Missing date of manufacture/import declaration.",
      "legal_reference": "Rule 6(1)(d) - Month and year of manufacture mandatory"
    },
    {
      "code": "LM-AUD-006",
      "field": "country_of_origin",
      "mandatory": false,
      "required_if_imported": true,
      "penalty": 10,
      "message": "Missing country of origin for imported goods.",
      "legal_reference": "Country of origin mandatory for imported products"
    },
    {
      "code": "LM-AUD-007",
      "field": "common_generic_name",
      "mandatory": true,
      "penalty": 15,
      "message": "Missing common or generic name of commodity.",
      "legal_reference": "Rule 6(1)(b) - Common or generic name mandatory"
    },
    {
      "code": "LM-AUD-008",
      "field": "manufacturer_address",
      "mandatory": true,
      "penalty": 15,
      "message": "Missing complete manufacturer/packer address.",
      "legal_reference": "Rule 6(1)(a) - Complete address of manufacturer mandatory"
    },
    {
      "code": "LM-AUD-009",
      "field": "importer_address",
      "mandatory": false,
      "required_if_imported": true,
      "penalty": 15,
      "message": "Missing importer name and address for imported goods.",
      "legal_reference": "Import condition - Importer details required for imported products"
    },
    {
      "code": "LM-AUD-010",
      "field": "net_quantity_unit_valid",
      "mandatory": true,
      "penalty": 10,
      "message": "Net quantity not in standard SI units (g, kg, ml, L, cm, m).",
      "legal_reference": "Rule 9 - Quantity in standard units only"
    },
    {
      "code": "LM-AUD-011",
      "field": "net_quantity_no_approximation",
      "mandatory": true,
      "penalty": 15,
      "message": "Net quantity contains prohibited expressions (approx, about, minimum, average, not less than).",
      "legal_reference": "Prohibited expressions in net quantity declaration"
    },
    {
      "code": "LM-AUD-012",
      "field": "mrp_format_valid",
      "mandatory": true,
      "penalty": 10,
      "message": "MRP not in correct format 'MRP Rs. X (inclusive of all taxes)'.",
      "legal_reference": "Rule 10 - MRP must be clear, unambiguous, and include all taxes"
    },
    {
      "code": "LM-AUD-013",
      "field": "price_not_exceeding_mrp",
      "mandatory": true,
      "penalty": 25,
      "message": "Selling price exceeds printed MRP - violation of Rule 18.",
      "legal_reference": "Rule 18 - Sale price cannot exceed MRP"
    }
  ],
  "validation_rules": {
    "net_quantity": {
      "allowed_units": ["g", "gram", "grams", "kg", "kilogram", "ml", "millilitre", "l", "litre", "cm", "centimetre", "m", "metre", "sq m", "square metre", "cubic m", "pcs", "pieces", "units"],
      "prohibited_expressions": ["approx", "approximately", "about", "minimum", "min", "average", "avg", "not less than", "atleast", "at least"],
      "si_units_only": true
    },
    "mrp": {
      "must_include_taxes": true,
      "valid_formats": ["MRP", "M.R.P.", "Maximum Retail Price"],
      "rounding_rules": {
        "less_than_50_paise": "round_down",
        "50_to_95_paise": "round_to_50_paise"
      }
    },
    "date_format": {
      "valid_formats": ["MM/YYYY", "Month YYYY", "MM-YYYY", "DD/MM/YYYY"]
    }
  },
  "maximum_permissible_error": {
    "weight_volume": [
      {"range": "up_to_50g_ml", "error_value": 9, "error_type": "absolute", "unit": "g_or_ml"},
      {"range": "50_to_100g_ml", "error_value": 4.5, "error_type": "absolute", "unit": "g_or_ml"},
      {"range": "100_to_200g_ml", "error_value": 4.5, "error_type": "percentage"},
      {"range": "200_to_300g_ml", "error_value": 9, "error_type": "absolute", "unit": "g_or_ml"},
      {"range": "300_to_500g_ml", "error_value": 3, "error_type": "percentage"},
      {"range": "500_to_1000g_ml", "error_value": 15, "error_type": "absolute", "unit": "g_or_ml"},
      {"range": "1000_to_10000g_ml", "error_value": 1.5, "error_type": "percentage"},
      {"range": "above_15000g_ml", "error_value": 1.0, "error_type": "percentage"}
    ],
    "length": {"up_to_10m": "2%", "above_10m": "1%"},
    "area": {"up_to_10sqm": "4%", "above_10sqm": "1%"},
    "number": "2%"
  },
  "exemptions": {
    "quantity_exemptions": [
      {"condition": "less_than_10g_or_10ml", "exempt": true},
      {"condition": "agricultural_produce_above_50kg", "exempt": true}
    ],
    "category_exemptions": [
      {"condition": "restaurant_fast_food", "exempt": true}
    ]
  },
  "penalties": {
    "general_violation": 2000,
    "registration_violation": 4000,
    "repeat_violation": "as_per_Act_Section_36"
  },
  "scoring_system": {
    "description": "Legal Metrology Compliance Scoring - Score Based Risk Assessment",
    "base_score": 100,
    "minimum_score": 0,
    "violation_categories": {
      "category_a": {
        "name": "Prohibited Practices (Very Serious Violations)",
        "deduction_per_violation": 25,
        "violations": [
          {
            "code": "LM-SCORE-A001",
            "description": "Using misleading words in quantity declaration (approx, about, minimum, average, not less than)",
            "field": "net_quantity_no_approximation",
            "points": 25
          },
          {
            "code": "LM-SCORE-A002",
            "description": "Selling above MRP - violation of Rule 18",
            "field": "price_not_exceeding_mrp",
            "points": 25
          },
          {
            "code": "LM-SCORE-A003",
            "description": "False or deceptive quantity declaration",
            "field": "false_quantity_declaration",
            "points": 25
          }
        ]
      },
      "category_b": {
        "name": "Missing Mandatory Declarations (Serious Violations)",
        "deduction_per_violation": 20,
        "violations": [
          {
            "code": "LM-SCORE-B001",
            "description": "Missing MRP (inclusive of all taxes)",
            "field": "mrp_inclusive_of_taxes",
            "points": 20
          },
          {
            "code": "LM-SCORE-B002",
            "description": "Missing Net Quantity",
            "field": "net_quantity",
            "points": 20
          },
          {
            "code": "LM-SCORE-B003",
            "description": "Missing Manufacturer/Packer/Importer Name & Address",
            "field": "manufacturer_or_importer",
            "points": 20
          },
          {
            "code": "LM-SCORE-B004",
            "description": "Missing Month & Year of Manufacture/Packing/Import",
            "field": "date_of_manufacture_or_import",
            "points": 20
          },
          {
            "code": "LM-SCORE-B005",
            "description": "Missing Customer Care Details",
            "field": "consumer_care_information",
            "points": 20
          },
          {
            "code": "LM-SCORE-B006",
            "description": "Missing Country of Origin (if imported)",
            "field": "country_of_origin",
            "points": 20
          }
        ]
      },
      "category_c": {
        "name": "Format / Declaration Errors (Moderate Violations)",
        "deduction_per_violation": 10,
        "violations": [
          {
            "code": "LM-SCORE-C001",
            "description": "Incorrect SI unit usage in quantity",
            "field": "net_quantity_unit_valid",
            "points": 10
          },
          {
            "code": "LM-SCORE-C002",
            "description": "Incorrect font size or visibility",
            "field": "font_size_visibility",
            "points": 10
          },
          {
            "code": "LM-SCORE-C003",
            "description": "Declaration not on Principal Display Panel",
            "field": "declaration_on_pdp",
            "points": 10
          },
          {
            "code": "LM-SCORE-C004",
            "description": "Improper MRP format",
            "field": "mrp_format_valid",
            "points": 10
          }
        ]
      },
      "category_d": {
        "name": "Minor Technical Issues",
        "deduction_per_violation": 5,
        "violations": [
          {
            "code": "LM-SCORE-D001",
            "description": "Spacing/alignment issues in declarations",
            "field": "spacing_alignment",
            "points": 5
          },
          {
            "code": "LM-SCORE-D002",
            "description": "Minor formatting inconsistencies",
            "field": "formatting_consistency",
            "points": 5
          }
        ]
      }
    },
    "risk_level_assessment": {
      "description": "Risk levels determined solely by compliance score",
      "levels": [
        {
          "score_range": "90-100",
          "risk_level": "Fully Compliant",
          "indicator": "✅",
          "action": "No action required",
          "penalty_risk": "None"
        },
        {
          "score_range": "70-89",
          "risk_level": "Minor Risk",
          "indicator": "⚠️",
          "action": "Address minor issues within 30 days",
          "penalty_risk": "Low"
        },
        {
          "score_range": "50-69",
          "risk_level": "Moderate Legal Risk",
          "indicator": "⚠️⚠️",
          "action": "Mandatory correction required within 15 days",
          "penalty_risk": "Moderate - Possible fine Rs. 2000-5000"
        },
        {
          "score_range": "0-49",
          "risk_level": "High Penalty Risk",
          "indicator": "❌",
          "action": "Immediate removal from sale, product detention required",
          "penalty_risk": "High - Possible fine Rs. 5000+ or imprisonment"
        }
      ]
    },
    "scoring_logic": {
      "step_1": "Start with base score of 100",
      "step_2": "For each Category A violation found, deduct 25 points",
      "step_3": "For each Category B violation found, deduct 20 points",
      "step_4": "For each Category C violation found, deduct 10 points",
      "step_5": "For each Category D violation found, deduct 5 points",
      "step_6": "If any Category A violation exists, cap maximum achievable score at 60",
      "step_7": "Ensure score does not go below 0",
      "step_8": "Match final score to risk level using risk_level_assessment ranges"
    }
  }
}
